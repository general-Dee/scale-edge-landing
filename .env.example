# Google Analytics 4 Measurement ID.
# Find it in GA4 Admin > Data Streams > (your web stream) > Measurement ID.
# Looks like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# LinkedIn Insight Tag Partner ID.
# Find it in LinkedIn Campaign Manager > Account Assets > Insight Tag > Install my Insight Tag.
# Looks like a numeric string, e.g. 1234567
NEXT_PUBLIC_LI_PARTNER_ID=

# Stripe Payment Link URL for the $147 Growth Snapshot checkout.
# Find it in Stripe Dashboard > Payment Links (create one for the Growth Snapshot product).
# Looks like: https://buy.stripe.com/xxxxxxxxxxxx
# Until this is set, the Snapshot CTA buttons render a disabled "coming soon" state
# instead of linking anywhere — do not hardcode a placeholder URL here.
NEXT_PUBLIC_SNAPSHOT_PAYMENT_LINK_URL=

# LinkedIn Conversion ID for the lead capture (checklist) conversion event.
# Find it in LinkedIn Campaign Manager > Account Assets > Conversion Tracking > (your conversion) > Conversion ID.
# Looks like a numeric string, e.g. 12345678
# Until this is set, lead capture tracking silently no-ops (GA4 event still fires).
NEXT_PUBLIC_LI_CONVERSION_ID_LEAD=

# LinkedIn Conversion ID for the Snapshot CTA click conversion event.
# Find it in LinkedIn Campaign Manager > Account Assets > Conversion Tracking > (your conversion) > Conversion ID.
# Looks like a numeric string, e.g. 12345678
# Until this is set, Snapshot CTA click tracking silently no-ops (GA4 event still fires).
NEXT_PUBLIC_LI_CONVERSION_ID_SNAPSHOT=

# ConvertKit API key (server-only — never expose this to the client).
# Find it in ConvertKit Dashboard > Account Settings > API Keys > API Key.
# Looks like: a1B2c3D4e5F6g7H8i9J0kL
CONVERTKIT_API_KEY=

# ConvertKit Form ID to subscribe leads to (server-only — never expose this to the client).
# Find it in ConvertKit Dashboard > Grow > Landing Pages & Forms > (your form) > Settings, or in the form's embed script/URL.
# Looks like a numeric string, e.g. 1234567
CONVERTKIT_FORM_ID=
# Until both CONVERTKIT_API_KEY and CONVERTKIT_FORM_ID are set, /api/lead falls
# back to logging leads server-side instead of sending them to ConvertKit.
